# ============================================================
#  SAO v3.0 — Variables de entorno (Next.js / Vercel)
# ============================================================

# --- Base de Datos (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/mydb?sslmode=require

# --- Autenticación Admin (legacy — se reemplaza por TenantAdmin en v3.1) ---
ADMIN_PASSWORD=

# --- Tenant por defecto (para desarrollo local sin subdominio) ---
DEFAULT_TENANT_SLUG=kh

# --- Google Cloud Storage ---
GCS_BUCKET=your-bucket-name
GCS_TENANT=your-tenant
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=

# --- Whisper STT (servidor Python local en la fábrica) ---
NEXT_PUBLIC_WHISPER_WS_URL=ws://localhost:8765

# --- Sentry ---
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
