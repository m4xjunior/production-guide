{
  "name": "sage-operator-sync",
  "version": "1.0.0",
  "private": true,
  "description": "Syncs operators from Sage SQL Server to Neon PostgreSQL",
  "scripts": {
    "setup": "npx prisma generate --schema=prisma/schema.prisma",
    "sync": "tsx src/index.ts",
    "sync:once": "SYNC_ONCE=true tsx src/index.ts"
  },
  "dependencies": {
    "mssql": "^11.0.1",
    "pg": "^8.13.0",
    "@prisma/client": "^7.4.2",
    "@prisma/adapter-pg": "^7.4.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "@types/mssql": "^9.1.0",
    "@types/pg": "^8.11.0"
  }
}
