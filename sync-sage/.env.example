# ── Neon PostgreSQL (copiar da Vercel: Settings > Environment Variables > DATABASE_URL) ──
DATABASE_URL=postgresql://...

# ── Tenant ID do KH ──
TENANT_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# ── Sage SQL Server ──
SAGE_HOST=localhost
SAGE_PORT=1433
SAGE_USER=sa
SAGE_PASSWORD=SUA_SENHA_AQUI
SAGE_DATABASE=KH
SAGE_ENCRYPT=false
SAGE_TRUST_CERT=true

# ── Mapeamento de tabelas/colunas (ajustar conforme o schema real do Sage) ──
SAGE_OPERATOR_TABLE=Operario
SAGE_CODE_COLUMN=id
SAGE_NAME_COLUMN=descripcion

SAGE_REFERENCE_TABLE=Referencia
SAGE_REF_CODE_COLUMN=id
SAGE_REF_NAME_COLUMN=descripcion

# ── Comportamento ──
SYNC_INTERVAL=60
