# ============================================================
#  sage-operator-sync — configuracao
#  Copie este arquivo para .env e preencha os valores reais
# ============================================================

# --- Sage SQL Server ---
SAGE_HOST=10.0.0.41
SAGE_PORT=1433
SAGE_USER=sa
SAGE_PASSWORD=SENHA_AQUI
SAGE_DATABASE=KH
SAGE_ENCRYPT=false
SAGE_TRUST_CERT=true

# --- Tabela de operarios ---
SAGE_OPERATOR_TABLE=Operario
SAGE_CODE_COLUMN=id
SAGE_NAME_COLUMN=descripcion

# --- Tabela de referencias de produto ---
SAGE_REFERENCE_TABLE=Referencia
SAGE_REF_CODE_COLUMN=id
SAGE_REF_NAME_COLUMN=descripcion

# --- Neon PostgreSQL (producao) ---
DATABASE_URL=postgresql://neondb_owner:SENHA@ep-orange-paper-ab890z35-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require

# --- Sync ---
SYNC_INTERVAL=60
# SYNC_ONCE=true  # descomente para testar uma vez e sair
